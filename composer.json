{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "alex-tsarkov/parsley",
    "type": "library",
    "description": "Parser combinators",
    "license": "MIT",
    "authors": [
        {
            "name": "Alex Tsarkov",
            "email": "alex.tsarkov@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-mbstring": "*",
        "ext-spl": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "testo/testo": "^0.10"
    },
    "autoload": {
        "psr-4": {
            "AlexTsarkov\\Parsley\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "main": "0.x-dev"
        }
    }
}
