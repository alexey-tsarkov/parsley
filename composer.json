{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "alex-tsarkov/parsley",
    "description": "Parser combinators for PHP",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Alexey Tsarkov",
            "email": "alex.tsarkov@gmail.com"
        }
    ],
    "support": {
        "email": "alex.tsarkov@gmail.com",
        "source": "https://github.com/alexey-tsarkov/parsley",
        "issues": "https://github.com/alexey-tsarkov/parsley/issues"
    },
    "require": {
        "php": "^8.4",
        "ext-mbstring": "*",
        "ext-spl": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "testo/testo": "^0.10"
    },
    "autoload": {
        "psr-4": {
            "AlexTsarkov\\Parsley\\": "src/"
        }
    },
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "main": "v0.x-dev"
        }
    },
    "archive": {
        "exclude": [
            "/tests/",
            "/testo.php",
            "/.github/",
            "/.gitignore",
            "/.php-cs-fixer.*"
        ]
    }
}
